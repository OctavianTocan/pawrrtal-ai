# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.venv/
.cache/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.vscode/
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example
!.env.docker

# Private
/private
.private

# Personal Effect-learning scaffolding (teach skill workspace). Not project artefacts.
/MISSION.md
/RESOURCES.md
/NOTES.md
/learning-records/
/lessons/

# Generated user workspaces (created by seed_workspace at runtime).
# Default ``WORKSPACE_BASE_DIR=/data/workspaces`` is overridden in
# local .env to ``./workspaces``, which lands at the repo root or
# under backend/ depending on cwd. Both are runtime artefacts.
workspaces/
backend/workspaces/

# testing & coverage
/coverage
coverage/
**/coverage/
.nyc_output/
*.lcov
.vitest-cache/
htmlcov/
.coverage
.coverage.*
junit.xml
test-results/
playwright-report/
# Stagehand E2E auxiliary artifacts:
#   - `.trace-extract/` is the temp dir created by the GIF afterEach
#     hook in `frontend/e2e/stagehand/fixtures.ts` to unzip trace.zip.
#   - `**/run.gif` is the per-test GIF artifact (also lives under
#     test-results/, but pattern protects against stragglers).
#   - `.stagehand-cache/` is NOT ignored — it's committed so CI shares
#     the warm Stagehand action cache (per the suite's README).
**/.trace-extract/
**/run.gif

# next.js
/.next/
/out/

# production
build/
cache/
dist/

# Bun runtime transpiler cache (XDG cache dir, *.pile files) — created when
# running the backend-ts Effect API under `bun run` / `bun --filter ... dev`.
# Per-developer, regenerated on every boot; never commit.
.cache/

# Local mirror created by a one-off rsync from `apps/api/test/` while
# diagnosing the Bun-runtime test fix. The file system has the directory
# locked (chflags-restored immutable) and the trash can't purge it; git
# must skip it. The canonical test tree lives next to it in `test/`.
backend-ts/apps/api/test.bak/

# Next
.next/

# misc
.DS_Store
Thumbs.db
*.pem
# IDEs / editors that aren't already covered above
.idea/
*.swp
*.swo
*~
# uv tool cache (per-developer; not the project lockfile, which IS tracked)
.uv-cache/
# Stagehand fixture's per-test screenshot dir used to feed ffmpeg.
# Lives under test-results/<spec>/.frames/ so it's transitively ignored
# by the test-results/ pattern, but explicit is better than implicit.
**/.frames/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# logs (including rotated logs like app.log.1, app.log.2.gz, etc.)
*.log
*.log.[0-9]*
*.log.[0-9]*.gz

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.docker

# repomix output files
repomix-output.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__
*.py[cod]
*$py.class
*.egg-info/
.tox/
.pyre/
.pytype/
pip-log.txt
pip-delete-this-directory.txt

# Database
agno.db
agno.db-shm
agno.db-wal

# sentrux local baseline (per-developer, not shared)
.sentrux/baseline.json

# Serena local memory output (generated by agent sessions)
.serena/memories/

package-lock.json

# react-dropdown and react-overlay are git submodules under frontend/lib/*
# (managed by .gitmodules).  The previous "nested git repo" pattern broke
# CI because the directory wasn't present on fresh checkouts; submodule
# tracking fixes that without forcing the package source into the parent
# repo's history.
# (No ignore needed — submodules are tracked normally by git.)

# Cursor IDE runtime state (generated every session, not config)
.cursor/hooks/state/

# Cursor Composer AI-generated plan files (ephemeral, not source-of-truth)
.cursor/plans/

# OpenCode internal generated artifacts
.opencode/package-lock.json

# Databases
*.db
# SQLite WAL-mode sidecars (created when the backend-ts Effect API opens
# pawrrtal.db under bun:sqlite). Ephemeral; regenerated alongside the .db.
*.db-shm
*.db-wal
*.db-journal

# Local vendor reference clones (not submodules). See backend/vendor/README.md.
backend/vendor/comcom/
backend/vendor/effect/

# Docker
*/.env.docker
