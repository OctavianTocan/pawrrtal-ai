{
	"name": "pawrrtal",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --port 53001",
		"build": "next build",
		"start": "next start",
		"typecheck": "tsc --noEmit",
		"test": "NODE_ENV=test vitest run",
		"test:watch": "vitest",
		"test:coverage": "NODE_ENV=test vitest run --coverage",
		"e2e": "playwright test",
		"e2e:stagehand": "playwright test --config=playwright.stagehand.config.ts",
		"lint": "bunx --bun @biomejs/biome lint --write",
		"format": "bunx --bun @biomejs/biome format --write",
		"fix": "bunx --bun @biomejs/biome check --write",
		"check": "bunx --bun @biomejs/biome check && tsc --noEmit && node ../scripts/check-file-lines.mjs && node ../scripts/check-nesting.mjs && node ../scripts/check-view-container.mjs",
		"generate:docs": "node ../node_modules/.bin/fumadocs-mdx source.config.ts",
		"arch:check": "bunx dependency-cruiser --config .dependency-cruiser.cjs --validate .dependency-cruiser.cjs app features components lib hooks"
	},
	"dependencies": {
		"@hugeicons/core-free-icons": "^4.1.2",
		"@hugeicons/react": "^1.1.6",
		"@json-render/core": "^0.19.0",
		"@json-render/react": "^0.19.0",
		"@octavian-tocan/react-chat-composer": "workspace:*",
		"@octavian-tocan/react-dropdown": "workspace:*",
		"@octavian-tocan/react-overlay": "workspace:*",
		"@radix-ui/react-use-controllable-state": "^1.2.2",
		"@tabler/icons-react": "^3.43.0",
		"@tanstack/react-query": "^5.100.9",
		"@types/mdx": "^2.0.13",
		"ai": "^6.0.177",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"embla-carousel-react": "^8.6.0",
		"fumadocs-core": "^16.8",
		"fumadocs-mdx": "^15.0",
		"fumadocs-ui": "^16.8",
		"lucide-react": "^1.14.0",
		"motion": "^12.34.0",
		"nanoid": "^5.1.6",
		"next": "16.2.6",
		"radix-ui": "^1.4.3",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"shiki": "^4.0.2",
		"sonner": "^2.0.7",
		"streamdown": "^2.2.0",
		"tailwind-merge": "^3.4.0",
		"tokenlens": "^1.3.1",
		"tw-animate-css": "^1.4.0",
		"use-stick-to-bottom": "^1.1.3"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@biomejs/biome": "2.4.15",
		"@browserbasehq/stagehand": "^3.3.0",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/postcss": "^4.3.0",
		"@tanstack/react-query-devtools": "^5.100.9",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.6.2",
		"@types/react": "19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"@vitest/coverage-v8": "^4.1.5",
		"agentation": "^3.0.2",
		"jsdom": "^29.1.1",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5",
		"zod": "^4.4.3"
	}
}
