{
  "name": "pawrrtal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "vitest",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "e2e": "playwright test",
    "e2e:stagehand": "playwright test --config=playwright.stagehand.config.ts",
    "lint": "bun biome lint --write",
    "format": "bun biome format --write",
    "fix": "bun biome check --write",
    "check": "bun biome check && bun run generate:docs && tsc --noEmit && node ../scripts/check-file-lines.mjs && node ../scripts/check-nesting.mjs && node ../scripts/check-view-container.mjs",
    "generate:docs": "node ../node_modules/.bin/fumadocs-mdx source.config.ts",
    "arch:check": "bunx dependency-cruiser --config .dependency-cruiser.cjs --validate .dependency-cruiser.cjs app features components lib hooks"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.2.0",
    "@hugeicons/react": "^1.1.6",
    "@json-render/core": "^0.19.0",
    "@json-render/react": "^0.19.0",
    "@octavian-tocan/react-chat-composer": "workspace:*",
    "@octavian-tocan/react-dropdown": "workspace:*",
    "@octavian-tocan/react-overlay": "workspace:*",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/mdx": "^2.0.14",
    "ai": "^7.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "fumadocs-core": "^16.9.3",
    "fumadocs-mdx": "^15.0.11",
    "fumadocs-ui": "^16.9.3",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "radix-ui": "^1.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "2.5.1",
    "@browserbasehq/stagehand": "^3.5.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "agentation": "^3.0.2",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  }
}
