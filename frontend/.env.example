# Pawrrtal Frontend Configuration
# Copy this file to .env.local (or set these in Vercel).

# Browser API base URL. Defaults to the local FastAPI dev server.
# Set to an empty string for same-origin reverse-proxy deployments.
NEXT_PUBLIC_BROWSER_API_BASE=http://localhost:8000

# Legacy name still supported as a fallback for existing deployments.
# Leave unset when using NEXT_PUBLIC_BROWSER_API_BASE, especially for same-origin deployments.
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Additional hostnames allowed to request the Next dev server.
# This checkout allows its Tailscale dev host by default in next.config.ts.
# NEXT_ALLOWED_DEV_ORIGINS=dev.example.test,*.dev.example.test

# The dev admin login button uses backend-only credentials.
# Configure ADMIN_EMAIL / ADMIN_PASSWORD in the backend environment.

# Optional visual annotation toolbar for design/debug sessions.
# It blocks normal page interactions while active, so leave it disabled
# for everyday development and Tailscale-served login testing.
# ENABLE_AGENTATION=true
