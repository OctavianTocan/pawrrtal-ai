# Pawrrtal Frontend Configuration
# Copy this file to .env.local (or set these in Vercel).

# Browser API calls are same-origin. Next.js rewrites local `/api/v1`,
# `/auth`, and `/users` requests to this backend origin.
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Additional hostnames allowed to request the Next dev server.
# NEXT_ALLOWED_DEV_ORIGINS=dev.example.test,*.dev.example.test

# The dev admin login button uses backend-only credentials.
# Configure ADMIN_EMAIL / ADMIN_PASSWORD in the backend environment.

# Optional visual annotation toolbar for design/debug sessions.
# It blocks normal page interactions while active, so leave it disabled
# for everyday development and Cloudflared-served login testing.
# ENABLE_AGENTATION=true
