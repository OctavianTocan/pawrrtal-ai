# .docignore — TSDoc coverage exclusions
#
# Paths listed here are skipped by `just check-docs` / `bun run lint:docs`.
# Format: one pattern per line, repo-root relative, gitignore-style globs.
#
#   frontend/components/ai-elements/   — skip a whole directory
#   frontend/components/ui/button.tsx  — skip a single file
#   frontend/components/ui/**          — skip everything under a directory
#   **/*.generated.ts                  — skip by filename pattern
#
# Blank lines and lines starting with # are ignored.

# ── Primitive / design-system component libraries ────────────────────────────
# These are low-level headless components (shadcn-style) where each exported
# sub-component (Root, Trigger, Content…) mirrors the upstream API surface.
# Documenting each forwarder would be noise rather than signal.
frontend/components/ai-elements/**
frontend/components/ui/**

# ── Vendored sibling packages ────────────────────────────────────────────────
# Each of these is a git-submoduled copy of an external @octavian-tocan
# package. Their docstring conventions belong to the upstream package, not
# the host app — our TSDoc gate would force changes that wouldn't survive
# the next submodule sync. Tests + stories under these paths are also
# already excluded from the frontend vitest runner.
frontend/lib/react-dropdown/**
frontend/lib/react-overlay/**
frontend/lib/react-chat-composer/**

# ── Stub modules ─────────────────────────────────────────────────────────────
# `__mocks__/` files exist solely to satisfy import resolution under vitest.
frontend/__mocks__/**

# ── Auto-generated and declaration files ─────────────────────────────────────
**/*.d.ts
# Fumadocs-mdx code-generated collection wrappers (re-built on `bun run
# generate:docs`). Their re-exports are upstream contracts, not ours to
# document.
frontend/.source/**
