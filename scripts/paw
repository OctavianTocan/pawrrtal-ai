#!/usr/bin/env bash
set -euo pipefail

launcher_path="${BASH_SOURCE[0]}"
while [[ -L "${launcher_path}" ]]; do
	launcher_dir="$(cd -P -- "$(dirname -- "${launcher_path}")" && pwd)"
	launcher_path="$(readlink -- "${launcher_path}")"
	if [[ "${launcher_path}" != /* ]]; then
		launcher_path="${launcher_dir}/${launcher_path}"
	fi
done

script_dir="$(cd -P -- "$(dirname -- "${launcher_path}")" && pwd)"
repo_root="$(cd -- "${script_dir}/.." && pwd)"
cli_entrypoint="${repo_root}/packages/paw-cli/src/Main.ts"

if ! command -v bun >/dev/null 2>&1; then
	printf 'Error: Bun is required to run paw. Install Bun and try again.\n' >&2
	exit 1
fi

if [[ ! -f "${cli_entrypoint}" ]]; then
	printf 'Error: could not locate Paw CLI entrypoint at %s\n' "${cli_entrypoint}" >&2
	exit 1
fi

cd "${repo_root}"
exec bun run "${cli_entrypoint}" "$@"
