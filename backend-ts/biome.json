{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "root": false,
  "extends": ["../biome.json"],
  "files": {
    "includes": ["**/*.ts", "**/*.json", "!**/node_modules"]
  },
  "vcs": {
    "enabled": false
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "none",
      "arrowParentheses": "always"
    }
  },
  "linter": {
    "rules": {
      "style": {
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false,
            "filenameCases": ["camelCase", "kebab-case"]
          }
        }
      },
      "correctness": {
        "useImportExtensions": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/Modules/**/*.ts",
        "**/Lib/**/*.ts",
        "**/Infrastructure/**/*.ts",
        "**/test/**/*.ts",
        "packages/api-core/src/Api.ts",
        "apps/api/src/App.ts",
        "apps/api/src/Main.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": {
              "level": "error",
              "options": {
                "strictCase": false,
                "filenameCases": ["PascalCase"]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["**/scratchpad/**"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": {
              "level": "error",
              "options": {
                "filenameCases": ["camelCase", "kebab-case"]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["**/index.ts"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    }
  ]
}
