# Pawrrtal backend — Docker Compose environment template
#
# Usage:
#   cp backend/.env.docker.example backend/.env.docker
#   # Fill in your API keys below
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build
#
# This file is the *Compose* variant — DATABASE_URL points at the bundled
# Postgres service and is overridden in docker-compose.yml.  Everything
# else maps 1:1 to ``backend/app/core/config.py::Settings``.
#
# The full reference (with every optional toggle) lives in
# ``backend/.env.example``.  This file only carries the variables a
# typical Compose deploy actually needs to set — leave the rest at their
# Settings defaults and override here when you want to deviate.

# ============================================================================
# DATABASE  (overridden by docker-compose.yml)
# ============================================================================
DATABASE_URL=postgresql://pawrrtal:pawrrtal_dev@postgres:5432/pawrrtal

# ============================================================================
# AUTH & SECURITY  (required)
# ============================================================================

# JWT secret. Generate: openssl rand -hex 32
AUTH_SECRET=change-me-generate-with-openssl-rand-hex-32

# Fernet key for per-workspace encrypted .env files.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WORKSPACE_ENCRYPTION_KEY=change-me-generate-with-fernet

# Base directory for per-workspace folders. Default matches docker-compose
# volume mount; change only if you remap the volume.
# WORKSPACE_BASE_DIR=/data/workspaces

# ============================================================================
# ENVIRONMENT + COOKIES
# ============================================================================
ENV=dev
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
CORS_ORIGINS=["http://localhost:3001"]
# COOKIE_DOMAIN=
# CORS_ORIGIN_REGEX=^https:\/\/.*\.vercel\.app$

# ============================================================================
# ACCESS CONTROL
# ============================================================================
# Both off by default so the demo Compose stack just works for one user.
# Set BACKEND_API_KEY and/or ALLOWED_EMAILS in any shared deploy.
# BACKEND_API_KEY=
# ALLOWED_EMAILS=
# DEMO_MODE=false

# ============================================================================
# LLM PROVIDERS  (GOOGLE_API_KEY required for default model)
# ============================================================================

GOOGLE_API_KEY=your-google-api-key-here
CLAUDE_CODE_OAUTH_TOKEN=
EXA_API_KEY=
XAI_API_KEY=

# ============================================================================
# AGENT LOOP SAFETY  (sane defaults — uncomment to override)
# ============================================================================
# AGENT_MAX_ITERATIONS=25
# AGENT_MAX_WALL_CLOCK_SECONDS=300
# AGENT_MAX_CONSECUTIVE_LLM_ERRORS=3
# AGENT_MAX_CONSECUTIVE_TOOL_ERRORS=5
# AGENT_LLM_RETRY_BACKOFF_SECONDS=1.0

# ============================================================================
# CLAUDE SDK GOVERNANCE
# ============================================================================
# CLAUDE_SANDBOX_ENABLED=false
# CLAUDE_SANDBOX_AUTO_ALLOW_BASH=true
# CLAUDE_SANDBOX_EXCLUDED_COMMANDS=sudo,ssh,scp,rsync
# CLAUDE_RETRY_MAX_ATTEMPTS=3
# CLAUDE_RETRY_BASE_DELAY_SECONDS=1.0
# CLAUDE_RETRY_MAX_DELAY_SECONDS=30.0
# CLAUDE_RETRY_BACKOFF_FACTOR=2.0

# ============================================================================
# WORKSPACE CONTEXT
# ============================================================================
# WORKSPACE_CONTEXT_ENABLED=true
# WORKSPACE_SKILLS_DIR_NAME=.claude/skills
# WORKSPACE_SETTINGS_FILENAME=.claude/settings.json

# ============================================================================
# IN-PROCESS PYTHON TOOL  (opt-in; NOT sandboxed)
# ============================================================================
# VIRTUAL_PYTHON_ENABLED=false
# VIRTUAL_PYTHON_TIMEOUT_SECONDS=30
# VIRTUAL_PYTHON_OUTPUT_CAP_BYTES=32000

# ============================================================================
# CHAT RATE LIMITING
# ============================================================================
# CHAT_RATE_LIMIT_PER_MINUTE=0

# ============================================================================
# GOVERNANCE: COST + AUDIT
# ============================================================================
# COST_TRACKER_ENABLED=true
# COST_MAX_PER_REQUEST_USD=1.0
# COST_MAX_PER_USER_DAILY_USD=10.0
# COST_RESET_WINDOW_HOURS=24
# AUDIT_LOG_ENABLED=true
# AUDIT_LOG_RETENTION_DAYS=90
# SECRET_REDACTION_ENABLED=true
# STRICT_CONVERSATION_READ_VALIDATION=true

# ============================================================================
# OPS PLATFORM: WEBHOOKS + SCHEDULER
# ============================================================================
# WEBHOOK_API_ENABLED=false
# WEBHOOK_API_SECRET=
# GITHUB_WEBHOOK_SECRET=
# SCHEDULER_ENABLED=false
# SCHEDULER_PERSISTENT_JOBSTORE=true

# ============================================================================
# OAUTH: GOOGLE + APPLE  (optional)
# ============================================================================
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
# APPLE_OAUTH_CLIENT_ID=
# APPLE_OAUTH_TEAM_ID=
# APPLE_OAUTH_KEY_ID=
# APPLE_OAUTH_PRIVATE_KEY=
# APPLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/apple/callback
# OAUTH_POST_LOGIN_REDIRECT=http://localhost:3001/

# ============================================================================
# CHANNELS: TELEGRAM
# ============================================================================
# Leave TELEGRAM_BOT_TOKEN empty to disable the channel entirely.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_VERBOSE_DEFAULT=1
# TELEGRAM_TYPING_REFRESH_SECONDS=2.5
# TELEGRAM_USE_DRAFT_STREAMING=false

# ============================================================================
# VOICE / SPEECH-TO-TEXT
# ============================================================================
# VOICE_PROVIDER=xai
# VOICE_MISTRAL_API_KEY=
# VOICE_OPENAI_API_KEY=
# VOICE_WHISPER_CPP_BINARY=
# VOICE_WHISPER_CPP_MODEL=base
# VOICE_MAX_SIZE_MB=25

# ============================================================================
# LOSSLESS CONTEXT MANAGEMENT (LCM)
# ============================================================================
# LCM_ENABLED=false
# LCM_FRESH_TAIL_COUNT=64
# LCM_LEAF_CHUNK_TOKENS=20000
# LCM_CONTEXT_THRESHOLD=0.75
# LCM_INCREMENTAL_MAX_DEPTH=1
# LCM_SUMMARY_MODEL=

# ============================================================================
# DEV ADMIN LOGIN
# ============================================================================
ADMIN_EMAIL=admin@pawrrtal-ai.dev
ADMIN_PASSWORD=admin1234

# ============================================================================
# OBSERVABILITY  (OpenTelemetry — read directly by the OTel SDK)
# ============================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:5899
# OTEL_EXPORTER_OTLP_PROTOCOL=http/json
# OTEL_SERVICE_NAME=pawrrtal-backend
# OTEL_EXPORTER_OTLP_HEADERS=
