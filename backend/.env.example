# Pawrrtal Backend Configuration
# Copy this file to .env and fill in the values
#
# ► Docker Compose quick-start (PostgreSQL already bundled):
#     cp backend/.env.docker backend/.env   # fill in API keys
#     docker compose up --build
#
# ► Manual / Railway setup: fill DATABASE_URL below.

# ===========================================
# DATABASE
# ===========================================

# PostgreSQL connection URL
# Railway auto-injects this for deployed services.
# For local dev, use Railway's external (public) URL:
DATABASE_URL=postgresql://postgres:<password>@<host>.railway.app:<port>/railway

# ===========================================
# AUTH & SECURITY
# ===========================================

# JWT secret key for signing authentication tokens
# Generate with: openssl rand -hex 32
AUTH_SECRET=your-secret-key-here

# ===========================================
# ACCESS CONTROL
# ===========================================

# If set, every API request must include the header: X-Pawrrtal-Key: <value>
# This is a transport-level gate — it rejects unknown clients before auth
# even runs, preventing strangers from using your backend URL.
# Generate with: openssl rand -hex 32
# Leave empty to disable (fine for local dev or the public demo instance).
# BACKEND_API_KEY=

# Comma-separated list of email addresses allowed to use this deployment.
# When set, authenticated users NOT on this list receive a 403 on any
# protected endpoint. Works across all login methods (Google, Apple,
# password) because all providers deliver a verified email address.
# Leave empty to allow all registered users (open / demo mode).
# ALLOWED_EMAILS=you@example.com,partner@example.com

# Encryption key for per-user workspace .env files (BYOK overrides).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WORKSPACE_ENCRYPTION_KEY=your-base64-key-here

# ===========================================
# ENVIRONMENT
# ===========================================

# "dev" or "prod"
# - dev: cookies without Secure flag (allows http)
# - prod: cookies with Secure flag (requires https)
ENV=dev

# Cookie domain for auth cookies. Leave unset for plain localhost dev — the cookie will be
# scoped to whatever host issued it (localhost), which both frontend and backend share.
# COOKIE_DOMAIN=
# Cross-site cookie behavior ("lax", "strict", "none"). Use "lax" for localhost dev.
# Set to "none" for Vercel previews (requires COOKIE_SECURE=true).
COOKIE_SAMESITE=lax
# Force the Secure flag on auth cookies (true/false). Set false for plain http://localhost dev.
# Required true if COOKIE_SAMESITE=none.
COOKIE_SECURE=false

# CORS allowed origins (JSON array). Match the browser origin (Next.js dev runs on :3001).
CORS_ORIGINS=["http://localhost:3001"]
# Production: set to your Tailscale ts.net URL (or custom domain)
# CORS_ORIGINS=["https://pawrrtal.[tailnet].ts.net"]

# ===========================================
# LLM PROVIDERS
# ===========================================

# Google Gemini API Key
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Claude Agent SDK OAuth token
# Required ONLY when a chat request resolves to a Claude model
# (claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5). Leave empty if
# you only use Gemini.
#
# Generate with: `claude setup-token` (after `npm i -g @anthropic-ai/claude-code`)
# or via the Anthropic Console.
#
# The Claude Agent SDK provider forwards this token to its CLI subprocess,
# so it does NOT need to be exported in your shell — `.env` is enough.
CLAUDE_CODE_OAUTH_TOKEN=

# ===========================================
# CHANNELS: TELEGRAM
# ===========================================

# Bot token from @BotFather. Use a *separate* dev bot locally
# (e.g. @YourAppDevBot) so a busted handler can't spam real users.
# Leaving this empty disables the Telegram channel entirely;
# /api/v1/channels/telegram/* will report a clean 503 to the frontend.
TELEGRAM_BOT_TOKEN=

# Bot username without the leading @. Surfaced to the frontend so it
# can render the t.me/<bot>?start=<code> deep link.
TELEGRAM_BOT_USERNAME=

# How the bot receives updates:
#   polling  - the FastAPI lifespan runs getUpdates in the background.
#              Works on any laptop with no inbound connectivity. Default.
#   webhook  - Telegram POSTs updates to TELEGRAM_WEBHOOK_URL. Requires
#              a public HTTPS URL; intended for production only.
TELEGRAM_MODE=polling

# Public HTTPS URL Telegram should hit when TELEGRAM_MODE=webhook.
# Ignored in polling mode.
TELEGRAM_WEBHOOK_URL=

# Optional shared secret Telegram echoes in the
# X-Telegram-Bot-Api-Secret-Token header on every webhook delivery.
# Leave empty to skip verification (not recommended for prod).
TELEGRAM_WEBHOOK_SECRET=

# ===========================================
# DEV ADMIN LOGIN
# ===========================================

# Seeded admin account used by the dev-only login shortcut.
# The shortcut is disabled automatically when ENV=prod.
ADMIN_EMAIL=admin@pawrrtal-ai.dev
ADMIN_PASSWORD=admin1234

# ===========================================
# BROWSER-USE E2E SUITE
# ===========================================
#
# The e2e-browser-use/ tests need an LLM to decide each step. Set ONE
# of (resolved in this order — first match wins):
#
#   ZAI_API_KEY        -> GLM-5V-Turbo via Z.AI (recommended; free
#                         tier; vision-capable; agent/coding tuned;
#                         OpenAI-compatible at api.z.ai)
#   OPENAI_API_KEY     -> gpt-4o-mini
#   ANTHROPIC_API_KEY  -> claude-haiku-4-5
#
# Without any key set, the suite is auto-skipped.
#
# Headless mode is on by default; set BROWSER_USE_HEADLESS=0 to watch
# the agent drive Chrome live.
#
# ZAI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# BROWSER_USE_HEADLESS=1
# E2E_BACKEND_URL=http://localhost:8000
# E2E_FRONTEND_URL=http://localhost:3001

# ===========================================
# OBSERVABILITY (OpenTelemetry / Raindrop Workshop)
# ===========================================
#
# Pawrrtal emits OpenLLMetry-shaped spans for every chat turn (turn
# root, LLM call, each tool call) via app/core/observability/workshop.py.
# Set OTEL_EXPORTER_OTLP_ENDPOINT to enable tracing — when unset the
# whole observability stack is a no-op.
#
# Local debugging with Raindrop Workshop (https://github.com/raindrop-ai/workshop):
#   curl -fsSL https://raindrop.sh/install | bash    # installs the daemon
#   # Workshop listens on :5899 by default. It only accepts JSON OTLP,
#   # not protobuf, so OTEL_EXPORTER_OTLP_PROTOCOL must be http/json.
#
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:5899
# OTEL_EXPORTER_OTLP_PROTOCOL=http/json
# OTEL_SERVICE_NAME=pawrrtal-backend
#
# Remote backends (Grafana Cloud, Honeycomb, etc.) work with the same
# spans — point OTEL_EXPORTER_OTLP_ENDPOINT at their OTLP/HTTP receiver
# and add OTEL_EXPORTER_OTLP_HEADERS=Authorization=...
