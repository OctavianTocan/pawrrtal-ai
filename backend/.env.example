# Pawrrtal Backend Configuration
# Copy this file to .env and fill in the values you need.
#
# Two paths to get going:
#
#   ► Docker Compose quick-start (PostgreSQL bundled):
#       cp backend/.env.docker.example backend/.env.docker
#       docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build
#
#   ► Manual / Railway / VPS: fill DATABASE_URL below and run `just dev`.
#
# Every variable maps to a field on ``backend/app/core/config.py::Settings``.
# Commented-out values show defaults — uncomment and override only what you
# actually want to change.
#
# Required at minimum: DATABASE_URL, AUTH_SECRET, GOOGLE_API_KEY,
# WORKSPACE_ENCRYPTION_KEY, CORS_ORIGINS.

# ============================================================================
# DATABASE
# ============================================================================

# PostgreSQL connection URL. Railway auto-injects this for deployed services.
#
# For Railway-hosted backends in the same project as the Postgres service, use
# the internal hostname (``*.railway.internal``) — usually wired via a service
# variable reference like ``${{Postgres.DATABASE_URL}}``. The internal network
# avoids Railway's public TCP proxy, which adds latency and is more aggressive
# about evicting idle connections (a stale-pool source of
# ``SSL SYSCALL error: EOF detected``). Only fall back to the public
# ``*.railway.app:<port>`` URL when connecting from outside the Railway project
# (local dev, CI, ad-hoc scripts).
#
# For local dev against Compose Postgres:
#   postgresql://pawrrtal:pawrrtal_dev@postgres:5432/pawrrtal
# DATABASE_URL=

# Filename used for the implicit SQLite fallback (only kicks in when
# DATABASE_URL is empty). Handy for spinning up parallel checkouts /
# experiments against their own ``.db`` file without spelling out a full
# ``sqlite:///...`` URL. An explicit DATABASE_URL always wins.
SQLITE_DB_FILENAME=pawrrtal.db

# ============================================================================
# AUTH & SECURITY  (required)
# ============================================================================

# JWT secret used by fastapi-users to sign session cookies.
# Generate with: openssl rand -hex 32
AUTH_SECRET=replace-me-with-openssl-rand-hex-32

# Encryption key for per-workspace .env overrides at rest (BYOK provider
# keys live there).  Only WORKSPACE_ENCRYPTION_KEY is used — the old
# FERNET_KEY name is no longer read.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WORKSPACE_ENCRYPTION_KEY=replace-me-with-fernet-generate-key-output

# Base directory holding per-workspace folders. Default works in Docker;
# override on bare-metal deploys where /data isn't writable.
WORKSPACE_BASE_DIR=/data/workspaces

# ============================================================================
# ENVIRONMENT + COOKIES
# ============================================================================

# "dev" or "prod" — dev relaxes the Secure cookie flag and enables the
# dev-only admin login shortcut.
ENV=dev

# Cookie domain. Leave unset on plain localhost dev. In staging/prod, set to
# the parent domain that the FE + API share (e.g. "pawrrtal.app").
# COOKIE_DOMAIN=

# Cross-site cookie behaviour: "lax" (default), "strict", or "none".
# "none" requires HTTPS (COOKIE_SECURE=true) and is the only value that
# survives a cross-origin FE → API call (Vercel preview → Railway API).
COOKIE_SAMESITE=lax

# Force Secure flag on cookies. Leave unset (None) to auto-detect from ENV.
COOKIE_SECURE=false

# CORS allowed origins (JSON array). Must include every browser origin
# that talks to the API: localhost in dev, your Vercel domain in prod.
CORS_ORIGINS=["http://localhost:53001"]

# Optional regex applied in addition to CORS_ORIGINS. Useful for Vercel
# previews where the subdomain changes per deploy.
# CORS_ORIGIN_REGEX=^https:\/\/.*\.vercel\.app$

# ============================================================================
# ACCESS CONTROL
# ============================================================================

# If set, every API request must include header: X-Pawrrtal-Key: <value>
# Transport-level gate that rejects unknown clients before auth runs.
# Generate with: openssl rand -hex 32
# BACKEND_API_KEY=

# Comma-separated email allowlist. When set, authenticated users not on
# this list receive 403. Works across all login methods.
# ALLOWED_EMAILS=you@example.com,partner@example.com

# Demo-mode toggle. When true, refuses to start the Telegram channel and
# enforces the demo restrictions in docs/deployment/demo-mode.md.
# DEMO_MODE=false

# ============================================================================
# LLM PROVIDERS  (at least GOOGLE_API_KEY required)
# ============================================================================

# Google Gemini — powers the default model.
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key

# Claude Agent SDK OAuth token — only needed when a chat resolves to a
# claude-* model (claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5).
# Generate with: `claude setup-token` (after `npm i -g @anthropic-ai/claude-code`)
CLAUDE_CODE_OAUTH_TOKEN=

# Exa web search (https://exa.ai). Powers the provider-agnostic
# `exa_search` tool. Empty → tool returns a "not configured" error.
# EXA_API_KEY=your-exa-api-key

# xAI (https://x.ai). Powers Grok chat when no workspace OAuth token
# or workspace-specific XAI_API_KEY is configured.
# XAI_API_KEY=your-xai-api-key

# ============================================================================
# AGENT LOOP SAFETY
# ============================================================================
# All four caps accept empty string → None to disable that specific guard.
# Defaults are sane for production; tighten on demo deploys.

# Hard cap on assistant turns per chat invocation.
# AGENT_MAX_ITERATIONS=25
# Wall-clock budget (seconds) for one chat invocation.
# AGENT_MAX_WALL_CLOCK_SECONDS=300
# Back-to-back LLM stream errors before the loop bails.
# AGENT_MAX_CONSECUTIVE_LLM_ERRORS=3
# Back-to-back tool failures before the loop bails.
# AGENT_MAX_CONSECUTIVE_TOOL_ERRORS=5
# Base backoff (seconds) between LLM retries; doubles each retry, capped at 30s.
# AGENT_LLM_RETRY_BACKOFF_SECONDS=1.0

# ============================================================================
# CLAUDE SDK GOVERNANCE  (used only when chat resolves to claude-* model)
# ============================================================================

# Pass the SDK's macOS Seatbelt sandbox option to the bundled CLI subprocess.
# CLAUDE_SANDBOX_ENABLED=false
# When true, Bash invocations are auto-allowed inside the sandbox.
# CLAUDE_SANDBOX_AUTO_ALLOW_BASH=true
# Comma-separated bash commands the SDK should NOT auto-allow.
# CLAUDE_SANDBOX_EXCLUDED_COMMANDS=sudo,ssh,scp,rsync

# Retry-with-backoff for transient Claude SDK errors.
# CLAUDE_RETRY_MAX_ATTEMPTS=3
# CLAUDE_RETRY_BASE_DELAY_SECONDS=1.0
# CLAUDE_RETRY_MAX_DELAY_SECONDS=30.0
# CLAUDE_RETRY_BACKOFF_FACTOR=2.0

# ============================================================================
# WORKSPACE CONTEXT  (CLAUDE.md / AGENTS.md / SOUL.md / skills / settings.json)
# ============================================================================

# When true, the chat router assembles the workspace system prompt from
# the workspace's CLAUDE.md/AGENTS.md/SOUL.md + skills/ + settings.json.
WORKSPACE_CONTEXT_ENABLED=true
# Workspace-relative path to the skills directory (each subdir has SKILL.md).
# WORKSPACE_SKILLS_DIR_NAME=.claude/skills
# How skill bodies are included in prompts: manifest (fast default), full, or off.
# WORKSPACE_SKILL_PROMPT_MODE=manifest
# Workspace-relative path to the Claude Code-compatible settings file.
# WORKSPACE_SETTINGS_FILENAME=.claude/settings.json

# ============================================================================
# IN-PROCESS PYTHON TOOL  (opt-in, NOT sandboxed)
# ============================================================================
# When true, the agent gets a `python` tool that runs LLM-supplied source
# via exec() in the FastAPI worker process. Single-tenant self-hosted
# only — the code can reach os.environ, subprocess, sockets.

# VIRTUAL_PYTHON_ENABLED=false
# Wall-clock cap (seconds) per call.
VIRTUAL_PYTHON_TIMEOUT_SECONDS=30
# Max bytes of captured stdout+stderr returned to the model (head+tail truncated).
VIRTUAL_PYTHON_OUTPUT_CAP_BYTES=32000

# ============================================================================
# CHAT RATE LIMITING
# ============================================================================

# Per-user chat rate limit (requests per 60-second rolling window).
# Zero disables the limit. Default off — pick a value for public deploys.
# CHAT_RATE_LIMIT_PER_MINUTE=0

# ============================================================================
# GOVERNANCE: COST TRACKING + AUDIT LOG
# ============================================================================

# Per-turn cost ledger writes. Disable for local dev.
COST_TRACKER_ENABLED=true
# Per-request hard cap (USD). Forwarded to the Claude SDK; mirrored in
# the agent loop for Gemini. Zero disables.
# COST_MAX_PER_REQUEST_USD=1.0
# Per-user rolling-window cap (USD). Zero disables the user-level cap.
# COST_MAX_PER_USER_DAILY_USD=10.0
# Length of the rolling window (hours).
# COST_RESET_WINDOW_HOURS=24

# Master switch for the audit logger. When false, the audit API returns 404.
AUDIT_LOG_ENABLED=true
# Retention for audit rows; the scheduler's purge job applies this.
# Zero disables the purge.
AUDIT_LOG_RETENTION_DAYS=90

# Master switch for the secret-redaction pass over log lines and persisted
# tool inputs. Off only for adversarial test runs.
# SECRET_REDACTION_ENABLED=true

# Strict mode for ConversationRead: 422 on a non-canonical stored model_id.
# Set false as an operator escape hatch — bad values fall back to the
# catalog default and are logged.
# STRICT_CONVERSATION_READ_VALIDATION=true

# ============================================================================
# OPS PLATFORM: WEBHOOKS  (removed compatibility placeholders)
# ============================================================================

# The backend restructure removed the POST /webhooks routes. These
# settings remain as no-op placeholders so existing .env files parse.
# WEBHOOK_API_ENABLED=false
# WEBHOOK_API_SECRET=
# GITHUB_WEBHOOK_SECRET=

# ============================================================================
# OPS PLATFORM: SCHEDULER  (PR #12)
# ============================================================================

# When false the APScheduler lifespan task never starts; the API
# routes still serve historical job rows but disable mutate verbs.
SCHEDULER_ENABLED=true
# When true, jobs persist to SQLAlchemyJobStore. False = in-memory only.
SCHEDULER_PERSISTENT_JOBSTORE=true

# ============================================================================
# OAUTH: GOOGLE  (optional — enables "Continue with Google")
# ============================================================================
# Get from: https://console.cloud.google.com/apis/credentials

# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# Must be an authorized redirect URI on the OAuth client.
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# ============================================================================
# OAUTH: APPLE  (optional — enables "Continue with Apple")
# ============================================================================
# Requires services ID, team ID, key ID, and the .p8 private key contents.

# APPLE_OAUTH_CLIENT_ID=
# APPLE_OAUTH_TEAM_ID=
# APPLE_OAUTH_KEY_ID=
# APPLE_OAUTH_PRIVATE_KEY=
# APPLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/apple/callback

# Where to send the user after successful OAuth sign-in. Override in prod
# to point at the deployed frontend (e.g. https://app.pawrrtal-ai.dev/).
# OAUTH_POST_LOGIN_REDIRECT=http://localhost:53001/

# ============================================================================
# CHANNELS: TELEGRAM
# ============================================================================
# Leaving TELEGRAM_BOT_TOKEN empty disables the entire channel — the
# /api/v1/channels/telegram/* routes return a clean 503.

# Bot token from @BotFather. Use a *separate* dev bot locally.
TELEGRAM_BOT_TOKEN=

# Bot username without the leading @ (we strip it for you if you forget).
TELEGRAM_BOT_USERNAME=your_bot_username

# How the bot receives updates: "polling" (default) or "webhook".
TELEGRAM_MODE=polling

# Public HTTPS URL Telegram POSTs updates to when TELEGRAM_MODE=webhook.
TELEGRAM_WEBHOOK_URL=

# Optional shared secret echoed in X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=

# Numeric Telegram user_id (e.g. 123456789 — what @userinfobot reports).
# When set, inbound Telegram messages from this user_id are auto-linked
# to the seeded ADMIN_EMAIL user without the manual `/start <code>`
# flow, and the dev-admin workspace is ensured on first contact. Pairs
# with the branch-scoped SQLITE_DB_FILENAME so each git branch's fresh
# DB picks up the Telegram identity automatically. Leave empty in
# production unless you specifically want that mapping.
TELEGRAM_DEV_ADMIN_ID=

# Default verbose level for new conversations: 0=quiet, 1=tool names,
# 2=detailed (+ thinking traces).
TELEGRAM_VERBOSE_DEFAULT=2
# Typing-indicator refresh interval (seconds). Telegram clears typing
# after ~5s so this must be faster.
TELEGRAM_TYPING_REFRESH_SECONDS=2
# Bot API 9.3+ animated streaming via sendMessageDraft. Falls back to
# editMessageText when aiogram doesn't expose the binding.
TELEGRAM_USE_DRAFT_STREAMING=false

# ============================================================================
# CHANNELS: GOOGLE CHAT (single-user dogfood)
# ============================================================================
# Receives Google Chat events over a Pub/Sub *pull* subscription (no public
# webhook needed) and replies via the Chat REST API. Leaving the service
# account / project / subscription empty disables the channel — the pull
# loop never starts. See app/channels/google_chat/.

# Path to the Google Cloud service-account JSON (scopes: chat.bot + pubsub).
GOOGLE_CHAT_SERVICE_ACCOUNT_FILE=
# Google Cloud project that owns the Pub/Sub topic + subscription.
GOOGLE_CHAT_PROJECT_ID=
# Pub/Sub pull subscription id that receives inbound Chat events.
GOOGLE_CHAT_SUBSCRIPTION_ID=
# Chat sender resource name (e.g. users/1234567890) auto-linked to the
# seeded ADMIN_EMAIL user — the single-user dogfood path. Leave empty to
# ignore unbound senders.
GOOGLE_CHAT_DEV_ADMIN_ID=
#
# --- Slash-command menu (one-time Console step) ---
# Slash commands work as plain "/cmd" text out of the box. To get them in
# the Chat autocomplete MENU, register each below in the Cloud Console —
# Google exposes NO API for this (configuration is Console-only):
#   APIs & Services → Google Chat API → Configuration → Commands → Add a command
# For each: pick the Command ID, set "Slash command", name, and description.
# The app dispatches by command text, so the IDs are yours to choose.
#   ID  Name        Description
#   1   /help       List the available commands
#   2   /new        Start a fresh conversation
#   3   /model      Show or set the model for this conversation
#   4   /thinking   Show or set reasoning effort (none|low|medium|high)
#   5   /verbose    Set detail level: 0 quiet, 1 tools, 2 thinking
#   6   /status     Show model, verbosity, and reasoning
#   7   /whoami     Show your Chat identity and Pawrrtal binding

# ============================================================================
# VOICE / SPEECH-TO-TEXT
# ============================================================================

# Voice/STT was removed in the backend restructure. These settings are
# no-op compatibility placeholders; voice attachments become metadata
# annotations instead of transcripts.
# VOICE_PROVIDER=xai
# VOICE_MISTRAL_API_KEY=
# VOICE_OPENAI_API_KEY=
# VOICE_WHISPER_CPP_BINARY=
# VOICE_WHISPER_CPP_MODEL=base
# VOICE_MAX_SIZE_MB=25

# ============================================================================
# LOSSLESS CONTEXT MANAGEMENT (LCM)
# ============================================================================

# Master switch for the DAG-based conversation compaction system.
LCM_ENABLED=true
# Last N raw messages kept verbatim, never compacted.
LCM_FRESH_TAIL_COUNT=64
# Approximate source-token ceiling per leaf summary.
LCM_LEAF_CHUNK_TOKENS=20000
# Auto-trigger compaction at this fraction of the model's window.
LCM_CONTEXT_THRESHOLD=0.75
# Condensation passes after each leaf compaction. 0=leaf-only, -1=unlimited.
LCM_INCREMENTAL_MAX_DEPTH=1
# Optional model override for compaction summarisation. Empty = same model.
LCM_SUMMARY_MODEL=

# ============================================================================
# DEV ADMIN LOGIN
# ============================================================================
# Seeded account used by the dev-only login shortcut. Disabled when ENV=prod.

ADMIN_EMAIL=admin@pawrrtal-ai.dev
ADMIN_PASSWORD=admin1234

# ============================================================================
# PLUGINS  (per-workspace BYOK — declared in backend/app/plugins/*/plugin.py)
# ============================================================================
# These are NOT read by Settings — each workspace's encrypted .env carries them
# and the plugin tools read them per call via resolve_api_key(workspace_id, ...).
# Listed here so operators know what each plugin needs to be useful:
#
#   Notion plugin (backend/app/plugins/notion/) — 18 tools:
#     NOTION_API_KEY            (required; get from https://www.notion.so/profile/integrations)
#
# To wire BYOK keys without going through the UI, POST them to
# /api/v1/workspaces/{workspace_id}/env — see WORKSPACE_ENCRYPTION_KEY above.

# ============================================================================
# OBSERVABILITY (OpenTelemetry / Raindrop Workshop)
# ============================================================================
# The backend reads OTEL_EXPORTER_OTLP_ENDPOINT from .env automatically.
# When set, the tracing stack boots and sends OTLP JSON spans.  Unset it
# and observability is a complete no-op.
#
# Local debugging with Raindrop Workshop (https://github.com/raindrop-ai/workshop):
#   curl -fsSL https://raindrop.sh/install | bash
#   # Workshop listens on :5899.
#
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:5899
# OTEL_SERVICE_NAME=pawrrtal-backend
#
# Remote backends (Grafana Cloud, Honeycomb, etc.) work with the same
# exporter — point OTEL_EXPORTER_OTLP_ENDPOINT at their OTLP/HTTP receiver
# and add OTEL_EXPORTER_OTLP_HEADERS=Authorization=...

# ============================================================================
# BROWSER-USE / E2E SUITE  (test-only — not read by the running backend)
# ============================================================================
# The e2e-browser-use/ tests need an LLM to decide each step. Set ONE
# of (resolved in this order — first match wins):
#
#   ZAI_API_KEY        → GLM-5V-Turbo via Z.AI (recommended; free tier)
#   OPENAI_API_KEY     → gpt-4o-mini
#   ANTHROPIC_API_KEY  → claude-haiku-4-5
#
# Without any key set, the suite is auto-skipped.
#
# ZAI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# BROWSER_USE_HEADLESS=1
# E2E_BACKEND_URL=http://localhost:8000
# E2E_FRONTEND_URL=http://localhost:53001
