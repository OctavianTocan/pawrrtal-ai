{
	"name": "@pawrrtal/electrobun",
	"version": "0.1.0",
	"private": true,
	"description": "Pawrrtal desktop shell — Electrobun spike replacing Electron.",
	"scripts": {
		"start": "PAWRRTAL_REPO_ROOT=$(cd .. && pwd) electrobun dev",
		"dev": "PAWRRTAL_REPO_ROOT=$(cd .. && pwd) electrobun dev",
		"dev:watch": "PAWRRTAL_REPO_ROOT=$(cd .. && pwd) electrobun dev --watch",
		"build:stable": "bun run scripts/build-with-frontend.ts --env=stable",
		"build:canary": "bun run scripts/build-with-frontend.ts --env=canary",
		"build:dev": "electrobun build",
		"build": "electrobun build --env=stable",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"chokidar": "^5.0.0",
		"electrobun": "^1.18.1"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@vitest/coverage-v8": "^4.1.8",
		"typescript": "^5.0.0",
		"vitest": "^4.1.8"
	}
}
