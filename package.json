{
  "name": "pawrrtal",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run dev.ts",
    "serve": "bun run serve.ts",
    "commit": "bun run commit.ts",
    "lint:file-lines": "node scripts/check-file-lines.mjs",
    "lint:view-container": "node scripts/check-view-container.mjs",
    "lint:docs": "bun run scripts/check-docs.ts",
    "skill-gen:generate": "bun run packages/ci/skill-gen/src/index.ts generate --output .agent/skills",
    "skill-gen:check": "bun run packages/ci/skill-gen/src/index.ts check --output .agent/skills",
    "skill-gen:e2e-test": "bun run packages/ci/skill-gen/src/index.ts e2e-test",
    "design:lint": "bunx @google/design.md lint DESIGN.md",
    "design:diff": "bunx @google/design.md diff",
    "design:export:css": "bunx @google/design.md export --format css-tailwind DESIGN.md",
    "themes:build": "bun run scripts/build-themes.ts"
  },
  "devDependencies": {
    "@google/design.md": "^0.3.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@types/bun": "^1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "mcporter": "^0.12.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "frontend",
    "frontend/lib/react-dropdown",
    "frontend/lib/react-overlay",
    "frontend/lib/react-chat-composer",
    "backend-ts/packages/api-core",
    "backend-ts/apps/api",
    "packages/ci/skill-gen"
  ],
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
